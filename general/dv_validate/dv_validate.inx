[Version]
Signature="$WINDOWS NT$"
Class=SoftwareComponent
ClassGuid={5c4c3332-344d-483c-8739-259e934c9cc8}
Provider=%ProviderString%
DriverVer=%DriverVersion%
CatalogFile=dv_validate.cat
PnpLockDown=1 

[DestinationDirs]
DefaultDestDir = 13

[SourceDisksNames]
1 = %DiskId1%,,,""

[SourceDisksFiles]
dv_validate.sys = 1,,

; ================= Install section =================

[Manufacturer]
%StdMfg%=Standard,NT$ARCH$.10.0...16299

[Standard.NT$ARCH$.10.0...16299]
%DVV.DeviceDesc%=dvv_driver, root\dvv_driver

[dvv_driver.NT$ARCH$]
CopyFiles=Drivers_Dir

[Drivers_Dir]
dv_validate.sys

; ================= Service installation =================

[dvv_driver.NT$ARCH$.Services]
AddService = dvv_driver_svc, %SPSVCINST_ASSOCSERVICE%, DVV_SVC_INS

[DVV_SVC_INS]
DisplayName    = %DVV.SVCDESC%
ServiceType    = 1                  ; SERVICE_KERNEL_DRIVER
StartType      = 3                  ; SERVICE_DEMAND_START
ErrorControl   = 1                  ; SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\dv_validate.sys

; ================= Strings =================

[Strings]
SPSVCINST_ASSOCSERVICE = 0x00000002
ProviderString         = "TODO Set Provider String"
StdMfg                 = "(Standard system devices)"
DiskId1                = "Sample DVV Driver Installation Disk #1"
DVV.DeviceDesc         = "Sample driver for Driver Verifier Validation"
DVV.SVCDESC            = "Rust Driver Verifier Validation Driver"